# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Channel ID for automated alerts (optional)
# Right-click channel -> Copy ID (enable Developer Mode first)
# Phase 6 event alerts post here (same channel as other bot alerts unless you split channels in Discord)
ALERT_CHANNEL_ID=123456789012345678

# DeepSeek API Key for sentiment analysis (optional)
DEEPSEEK_API_KEY=your_deepseek_key_here

# NEW — Persistence
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Optional: direct Postgres URL (Supabase Dashboard → Settings → Database) to run migrations/*.sql via psql
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres

# NEW — Data APIs
FRED_API_KEY=...
FINNHUB_API_KEY=...                         # optional, phase 3+
SEC_USER_AGENT="Ahmed Alshaer your@email.com"   # REQUIRED by SEC

# NEW — Optional Claude for synthesis (else DeepSeek is used)
ANTHROPIC_API_KEY=sk-ant-...
# Set to 1 to build briefings without calling the synthesis LLM (prompt tuning / saving tokens)
BRIEFING_SKIP_SYNTHESIS=0
# Daily cap on input+output tokens for all LLM usage (synthesis + filing summaries); default 50000
DAILY_LLM_BUDGET_TOKENS=50000

# NEW — Error handling + structured logs (core/ + jobs/)
ERROR_CHANNEL_ID=...
# JSON logs for Railway; DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Railway sets PORT for the /health HTTP probe (default 8080 locally)
# PORT=8080

# NEW — Timezone
BRIEFING_TZ=America/New_York
